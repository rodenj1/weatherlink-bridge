# WeatherLink API credentials (required)
WEATHERLINK__API_KEY=your_api_key_here
WEATHERLINK__API_SECRET=your_api_secret_here
WEATHERLINK__STATION_ID=your_station_id_here

# Weather Underground (optional, disabled by default)
WUNDERGROUND__ENABLED=false
WUNDERGROUND__STATION_ID=your_wu_station_id
WUNDERGROUND__API_KEY=your_wu_api_key

# Windy (optional, disabled by default)
WINDY__ENABLED=false
WINDY__STATION_ID=your_windy_station_id
WINDY__API_KEY=your_windy_api_key

# Application settings
LOG_LEVEL=INFO
UPDATE_INTERVAL_MINS=5
